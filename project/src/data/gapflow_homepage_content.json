    "name": "Gapflow.ai — Homepage (Modular Spec, Bolt-ready)",
    "version": "0.2.0",
    "created_at": "2025-11-06T12:15:34.569247",
    "viewport_strategy": "desktop-first-responsive",
    "theme": "make-style",
    "designer_notes": [
      "This spec is modular. Each section is a bolt:section node with a unique id.",
      "All spacings reference spacing tokens; do not hardcode px except where explicitly noted.",
      "Use CSS variables from the attached theme for colors, radius, shadows, motion."
    ],
    "notes": "Content layer filled with real messaging for Gapflow.ai (broad use beyond call centres)."
  },
  "tokens": {
    "colors": {
      "primary-gradient": [
        "#6B4BFF",
        "#9A68FF"
      ],
      "accent-green": "#32D38A",
      "neutral-100": "#FFFFFF",
      "neutral-200": "#F7F8FC",
      "neutral-300": "#F3F5FB",
      "neutral-400": "#E3E6EF",
      "neutral-800": "#202124",
      "neutral-600": "#5F6368",
      "muted": "#9AA0A6",
      "hero-dark-start": "#0B0E1A",
      "hero-dark-end": "#191E3A"
    },
    "typography": {
      "font-heading": "Poppins, Inter, Arial, sans-serif",
      "font-body": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif",
      "h1": {
        "size": 56,
        "line": 64,
        "weight": 700,
        "tracking": -0.5
      },
      "h2": {
        "size": 40,
        "line": 48,
        "weight": 700,
        "tracking": -0.2
      },
      "h3": {
        "size": 28,
        "line": 36,
        "weight": 700
      },
      "body-lg": {
        "size": 18,
        "line": 28,
        "weight": 400
      },
      "body": {
        "size": 16,
        "line": 26,
        "weight": 400
      },
      "caption": {
        "size": 12,
        "line": 18,
        "weight": 400
      }
    },
    "radius": {
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 24,
      "xxl": 32
    },
    "shadows": {
      "card": "0 2px 6px rgba(0,0,0,0.06)",
      "elevated": "0 8px 24px rgba(0,0,0,0.12)",
      "glow": "0 0 24px rgba(201,198,249,0.55)"
    },
    "spacing": {
      "xs": 8,
      "sm": 12,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48,
      "section": 100
    },
    "z": {
      "base": 1,
      "raised": 10,
      "modal": 1000
    },
    "breakpoints": {
      "desktop": 1200,
      "tablet": 992,
      "mobile": 768
    },
    "motion": {
      "durations": {
        "fast": 150,
        "base": 250,
        "slow": 400,
        "bg": 8000
      },
      "easing": {
        "inout": "cubic-bezier(.4,0,.2,1)"
      },
      "scroll_reveal": {
        "type": "fade-up",
        "distance": 24,
        "delay_step": 60
      }
    }
  },
  "components": {
    "button": {
      "props": {
        "variant": [
          "primary",
          "secondary",
          "ghost"
        ],
        "size": [
          "sm",
          "md",
          "lg"
        ],
        "icon": "optional-left"
      },
      "render": "button.bolt-btn[data-variant][data-size] span.label + optional svg.icon",
      "interaction": "hover: scale(1.03) + gradient-glow; focus-visible outline"
    },
    "card": {
      "props": {
        "elevation": [
          "base",
          "raised"
        ],
        "interactive": [
          true,
          false
        ],
        "padding": [
          "md",
          "lg"
        ]
      },
      "render": "div.bolt-card > header + div.content + optional footer",
      "interaction": "hover: translateY(-3px) + border-accent + shadow-elevated when interactive"
    },
    "pill": {
      "props": {
        "tone": [
          "accent",
          "muted"
        ],
        "icon": "optional-left"
      },
      "render": "span.bolt-pill[aria-label]"
    },
    "icon": {
      "props": {
        "name": "string",
        "size": [
          "sm",
          "md",
          "lg"
        ]
      },
      "render": "svg use href='#icon-{name}' with gradient fill on hover"
    },
    "logo_wall": {
      "props": {
        "columns": 6,
        "gap": "lg"
      },
      "render": "ul.bolt-logos > li > img[alt]"
    },
    "flow_canvas": {
      "description": "Hero animation / visual builder preview with nodal connections",
      "render": "canvas#flow-hero + data-driven nodes in absolutely positioned layer",
      "data_schema": {
        "nodes": [
          {
            "id": "string",
            "x": "number",
            "y": "number",
            "label": "string",
            "icon": "string",
            "state": [
              "idle",
              "active",
              "success"
            ]
          }
        ],
        "edges": [
          {
            "from": "id",
            "to": "id",
            "animated": true
          }
        ]
      },
      "interaction": "idle: slow background sweep; on hover over node: pulse ring; on intersection in viewport: animate lines"
    }
  },
  "layout": {
    "container": {
      "max_width": 1200,
      "padding_x": "xl"
    },
    "grid": {
      "columns": 12,
      "gutter": "lg"
    },
    "section_defaults": {
      "padding_y": "section"
    }
  },
